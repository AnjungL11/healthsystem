// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  // output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 业务状态枚举
enum QuizStatus {
  IN_PROGRESS
  COMPLETED
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  EXPIRED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ExerciseFrequency {
  RARELY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BodyType {
  APPLE
  PEAR
  HOURGLASS
  INVERTED_TRIANGLE
  RECTANGLE
}

enum DietType {
  STANDARD
  VEGAN
  VEGETARIAN
  KETO
  PALEO
  MEDITERRANEAN
}

enum SleepQuality {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum StressLevel {
  LOW
  MEDIUM
  HIGH
  EXTREME
}


// 核心数据模型
model User {
  id           String               @id @default(uuid())
  sessionId    String               @unique @map("session_id")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  
  quizSession  QuizSession?
  subscription Subscription?
  payments     PaymentTransaction[] // 关联支付流水记录

  @@map("users")
}

model QuizSession {
  id           String             @id @default(uuid())
  userId       String             @unique @map("user_id")
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  currentStep  Int                @default(1) @map("current_step")
  status       QuizStatus         @default(IN_PROGRESS)
  
  // 基础物理体征
  gender       Gender?
  age          Int?
  height       Float?
  weight       Float?
  targetWeight Float?             @map("target_weight")
  
  // 目标与身型
  bodyType     BodyType?          @map("body_type")
  targetAreas  String[]           // 目标部位多选，例如 ["BELLY", "THIGHS", "ARMS"]
  
  // 活动与运动
  exerciseFreq ExerciseFrequency? @map("exercise_freq")
  dailySteps   Int?               @map("daily_steps") // 每日步数
  
  // 营养与饮食习惯
  dietType     DietType?          @default(STANDARD) @map("diet_type")
  waterHabit   String?            @map("water_habit") // 饮水习惯
  
  // 生活方式与心理
  sleepHours   Float?             @map("sleep_hours")
  sleepQuality SleepQuality?      @map("sleep_quality")
  stressLevel  StressLevel?       @map("stress_level")
  badHabits    String[]           // 不良习惯多选，例如 ["LATE_NIGHT_SNACK", "SWEETS", "ALCOHOL"]
  
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  assessmentResult AssessmentResult?
  @@map("quiz_sessions")
}

model AssessmentResult {
  id                  String      @id @default(uuid())
  quizSessionId       String      @unique @map("quiz_session_id")
  quizSession         QuizSession @relation(fields: [quizSessionId], references: [id], onDelete: Cascade)
  
  bmi                 Float
  recommendedCalories Int         @map("recommended_calories")
  targetDate          DateTime    @map("target_date")
  // 存储预测曲线数据，鉴权拦截时针对此字段进行脱敏
  predictionCurve     Json?       @map("prediction_curve") 
  
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  @@map("assessment_results")
}

model Subscription {
  id          String             @id @default(uuid())
  userId      String             @unique @map("user_id")
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  status      SubscriptionStatus @default(INACTIVE)
  paidAt      DateTime?          @map("paid_at")
  expiresAt   DateTime?          @map("expires_at") // 支持未来订阅过期逻辑
  
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model PaymentTransaction {
  id                String        @id @default(uuid())
  userId            String        @map("user_id")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount            Int           // 交易金额
  currency          String        @default("USD")
  status            PaymentStatus @default(PENDING)
  providerReference String?       @map("provider_reference") // 模拟第三方支付平台的订单号
  
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@index([userId])
  @@map("payment_transactions")
}